---
const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
const currentPath = Astro.url.pathname;
const studyRoot = `${BASE}study`;
const artRoot = `${BASE}art`;
const isLab =
  currentPath.startsWith(studyRoot) ||
  currentPath.startsWith(`${BASE}translation`) ||
  currentPath.startsWith(`${BASE}research`) ||
  currentPath.startsWith(`${BASE}novel`) ||
  currentPath.startsWith(`${BASE}storage`);
const isArt = currentPath.startsWith(artRoot);
const section = isLab ? "lab" : "comm";
const titleIconSrc = `${BASE}images/deco/${
  section === "lab" ? "neco2.png" : isArt ? "neco3.png" : "neco.png"
}`;
const homeHref = section === "lab" ? `${BASE}storage` : BASE;
const siteTitle = section === "lab" ? "ねこねこ物置" : "ねこねこ通信";
const sectionLinks = [
  { href: BASE, label: "カイエ", active: section === "comm" },
  { href: `${BASE}storage`, label: "物置", active: section === "lab" },
];
---
<header class="siteHeader">
  <div class="headerTop">
    <div class="headerLeft">
      <nav class="headerControls" aria-label="サイト内メニュー">
        {sectionLinks.map((item) => (
          <a
            href={item.href}
            class={`sectionLink${item.active ? " isCurrent" : ""}`}
            aria-current={item.active ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <h1 class="siteTitle" style="margin:0;">
      <a href={homeHref} class={`siteTitleLink${section === "lab" ? " isLab" : ""}`} aria-label={siteTitle}>
        <img
          id="siteTitleIcon"
          src={titleIconSrc}
          alt=""
          class="siteTitleIcon"
        />
        <span class="srOnly">{siteTitle}</span>
      </a>
    </h1>

    <div class="headerRight">
      <div class="headerUtility"></div>
    </div>
  </div>

  <style>
    .siteTitleLink {
      color: var(--ink);
      text-decoration: none;
      letter-spacing: 0.03em;
      display: inline-block;
      position: relative;
      line-height: 1.2;
    }

    .siteTitle {
      font-size: 1.34rem;
      font-weight: 500;
      line-height: 1.2;
      margin: 0;
      grid-column: 2;
      justify-self: center;
    }

    .siteTitleIcon {
      position: absolute;
      right: calc(100% + 10px);
      top: 50%;
      transform: translateY(-50%);
      height: 44px;
      width: 44px;
      display: block;
      object-fit: contain;
      object-position: center;
    }

    .srOnly {
      border: 0;
      clip: rect(0 0 0 0);
      clip-path: inset(50%);
      height: 1px;
      margin: -1px;
      overflow: hidden;
      padding: 0;
      position: absolute;
      width: 1px;
      white-space: nowrap;
    }

    .sectionLink {
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 2px 0;
      line-height: 1.2;
      text-decoration: none;
      color: var(--ink);
      opacity: 0.82;
      letter-spacing: 0.04em;
      font-size: 0.96rem;
    }

    .sectionLink:hover {
      opacity: 1;
      text-decoration: underline;
      text-underline-offset: 0.18em;
    }

    .sectionLink.isCurrent {
      opacity: 1;
      font-weight: 600;
    }

    .headerControls {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 14px;
      flex-shrink: 0;
    }

    .headerLeft {
      grid-column: 1;
      justify-self: start;
      display: flex;
      align-items: flex-start;
      min-width: 0;
    }

    .headerTop {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 8px;
    }

    .headerRight {
      grid-column: 3;
      justify-self: end;
      display: flex;
      align-items: center;
      min-width: 0;
    }

    .headerQuickNav {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 8px 14px;
      align-items: center;
      min-width: 0;
    }

    .headerQuickLink {
      position: relative;
      display: inline-grid;
      place-items: center;
      width: 24px;
      height: 24px;
      color: var(--muted);
      text-decoration: none;
      line-height: 1.2;
    }

    .headerQuickLink:hover,
    .headerQuickButton:hover {
      opacity: 0.78;
    }

    .headerQuickLink::after,
    .headerQuickButton::after {
      content: attr(data-label);
      position: absolute;
      top: calc(100% + 6px);
      right: 0;
      padding: 4px 7px;
      border: 1px solid var(--line);
      background: rgba(252, 249, 242, 0.98);
      color: var(--muted);
      font-size: 0.72rem;
      line-height: 1.2;
      white-space: nowrap;
      opacity: 0;
      pointer-events: none;
      transform: translateY(-2px);
      transition: opacity 0.14s ease, transform 0.14s ease;
      z-index: 6;
    }

    .headerQuickLink:hover::after,
    .headerQuickLink:focus-visible::after,
    .headerQuickButton:hover::after,
    .headerQuickButton:focus-visible::after {
      opacity: 1;
      transform: translateY(0);
    }

    .headerQuickButton {
      position: relative;
      display: inline-grid;
      place-items: center;
      width: 24px;
      height: 24px;
      color: var(--muted);
      text-decoration: none;
      line-height: 1.2;
      border: 0;
      background: transparent;
      cursor: pointer;
      padding: 0;
    }

    .headerQuickIcon {
      width: 1.1em;
      text-align: center;
      font-size: 1rem;
    }

    .headerUtility {
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    @media (max-width: 700px) {
      .headerTop {
        grid-template-columns: 1fr;
        justify-items: stretch;
        gap: 10px;
      }

      .headerLeft {
        grid-column: 1;
        justify-self: start;
      }

      .siteTitle {
        grid-column: 1;
        justify-self: center;
        width: 100%;
        text-align: center;
      }

      .siteTitleLink {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding-left: 0;
      }

      .siteTitleIcon {
        position: static;
        transform: none;
        width: 32px;
        height: 32px;
      }

      .headerControls {
        justify-content: flex-start;
      }

      .headerRight {
        grid-column: 1;
        justify-self: center;
      }

    .headerQuickNav,
    .headerUtility {
      justify-content: center;
      gap: 8px 16px;
    }

    .headerQuickLink::after {
      left: 50%;
      right: auto;
      transform: translate(-50%, -2px);
    }

      .headerQuickLink:hover::after,
      .headerQuickLink:focus-visible::after,
      .headerQuickButton:hover::after,
      .headerQuickButton:focus-visible::after {
        transform: translate(-50%, 0);
      }

      .headSearchPanel {
        top: var(--site-header-bottom, var(--float-panel-top-current, var(--float-panel-top-mobile)));
      }
    }
  </style>
</header>
