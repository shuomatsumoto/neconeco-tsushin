---
const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
const currentPath = Astro.url.pathname;
const studyRoot = `${BASE}study`;
const isLab =
  currentPath.startsWith(studyRoot) ||
  currentPath.startsWith(`${BASE}translation`) ||
  currentPath.startsWith(`${BASE}research`) ||
  currentPath.startsWith(`${BASE}novel`) ||
  currentPath.startsWith(`${BASE}genealogy`);
const titleIconSrc = `${BASE}images/deco/${isLab ? "neco2.png" : "neco.png"}`;
const searchAction = `${BASE}${isLab ? "study/search" : "search"}`;
const searchLabel = isLab ? "研究所内の検索" : "記事と日記の検索";
const searchPlaceholder = isLab ? "研究所を検索" : "記事や日記を検索";
---
<header class="siteHeader">
  <div class="headerTop">
    <div class="headerLeft">
      <div class="headerControls">
        <button id="sunFab" class="sunFab" type="button" aria-label="menu" aria-expanded="false">
          ☀️
        </button>

        <button
          id="searchFab"
          class="searchFab"
          type="button"
          aria-label="search"
          aria-expanded="false"
        >
          🔍
        </button>

        <a
          href={isLab ? BASE : studyRoot}
          class="labLink"
          aria-label={isLab ? "ねこねこ通信へ" : "ねこねこ研究所へ"}
        >
          {isLab ? "✉️" : "🧪"}
        </a>
      </div>
    </div>

    <h1 class="siteTitle" style="margin:0;">
      <a href={isLab ? studyRoot : BASE} class={`siteTitleLink${isLab ? " isLab" : ""}`}>
        <img
          id="siteTitleIcon"
          src={titleIconSrc}
          alt=""
          class="siteTitleIcon"
        />
        <span>{isLab ? "ねこねこ研究所" : "ねこねこ通信"}</span>
      </a>
    </h1>
  </div>

  <form
    id="headSearch"
    class="headSearchPanel"
    action={searchAction}
    method="get"
    role="search"
    aria-label={searchLabel}
    data-open="false"
  >
    <input
      id="headSearchInput"
      class="headSearchInput"
      type="search"
      name="q"
      placeholder={searchPlaceholder}
    />
  </form>

  <style>
    .siteTitleLink {
      color: var(--ink);
      text-decoration: none;
      letter-spacing: 0.03em;
      display: inline-block;
      position: relative;
      line-height: 1.2;
    }

    .siteTitle {
      font-size: 1.34rem;
      font-weight: 500;
      line-height: 1.2;
      margin: 0;
      grid-column: 2;
      justify-self: center;
    }

    .siteTitleIcon {
      position: absolute;
      right: calc(100% + 10px);
      top: 50%;
      transform: translateY(-50%);
      height: 44px;
      width: 44px;
      display: block;
      object-fit: contain;
      object-position: center;
    }

    .labLink {
      width: 24px;
      height: 24px;
      cursor: pointer;
      display: grid;
      place-items: center;
      font-size: 16px;
      padding: 0;
      line-height: 1;
      text-decoration: none;
    }

    .headerControls {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 8px;
      flex-shrink: 0;
    }

    .headerLeft {
      grid-column: 1;
      justify-self: start;
      display: flex;
      align-items: flex-start;
      min-width: 0;
    }

    .headerTop {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 8px;
    }

    .headSearchPanel {
      position: fixed;
      top: var(--site-header-bottom, var(--float-panel-top-current, var(--float-panel-top)));
      left: 50%;
      transform: translate(-50%, -8px);
      width: min(940px, calc(100vw - 40px));
      margin: 0;
      padding: 8px 14px;
      background: rgba(252, 249, 242, 0.98);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
      border-radius: 0 0 12px 12px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.18s ease, transform 0.18s ease;
      z-index: 36;
    }

    .headSearchPanel[data-open="true"] {
      opacity: 1;
      pointer-events: auto;
      transform: translate(-50%, 0);
    }

    .headSearchInput {
      width: 100%;
      height: 36px;
      border: 0;
      border-radius: 0;
      background: transparent;
      color: var(--ink);
      padding: 0 8px;
      font-size: 0.86rem;
      font-family: inherit;
    }

    .headSearchInput:focus {
      outline: none;
    }

    .searchFab {
      width: 24px;
      height: 24px;
      border: 0;
      background: transparent;
      cursor: pointer;
      display: grid;
      place-items: center;
      font-size: 16px;
      padding: 0;
      line-height: 1;
    }

    .sunFab {
      width: 24px;
      height: 24px;
      border: 0;
      background: transparent;
      cursor: pointer;
      display: grid;
      place-items: center;
      font-size: 16px;
      padding: 0;
      line-height: 1;
      transition: transform 0.18s ease;
    }

    .sunFab[aria-expanded="true"] {
      transform: rotate(18deg);
    }

    @media (max-width: 700px) {
      .headerTop {
        grid-template-columns: 1fr;
        justify-items: stretch;
        gap: 10px;
      }

      .headerLeft {
        grid-column: 1;
        justify-self: start;
      }

      .siteTitle {
        grid-column: 1;
        justify-self: center;
        width: 100%;
        text-align: center;
      }

      .siteTitleLink {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding-left: 0;
      }

      .siteTitleIcon {
        position: static;
        transform: none;
        width: 32px;
        height: 32px;
      }

      .headerControls {
        justify-content: flex-start;
      }

      .headSearchPanel {
        top: var(--site-header-bottom, var(--float-panel-top-current, var(--float-panel-top-mobile)));
      }
    }
  </style>

  <script is:inline>
    (function () {
      function onReady(fn) {
        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", fn, { once: true });
        } else {
          fn();
        }
      }

      onReady(function () {
        var header = document.querySelector(".siteHeader");
        var btn = document.getElementById("searchFab");
        var form = document.getElementById("headSearch");
        var input = document.getElementById("headSearchInput");
        if (!btn || !form || !input || !header) return;

        function syncPanelTop() {
          var rect = header.getBoundingClientRect();
          var top = Math.max(0, Math.ceil(rect.bottom));
          var topRow = header.querySelector(".headerTop");
          var topRowBottom = top;
          if (topRow) {
            var topRowRect = topRow.getBoundingClientRect();
            topRowBottom = Math.max(0, Math.ceil(topRowRect.bottom));
          }
          document.documentElement.style.setProperty("--site-header-toprow-bottom", topRowBottom + "px");
          document.documentElement.style.setProperty("--site-header-bottom", top + "px");
          document.documentElement.style.setProperty("--float-panel-top-current", top + "px");
        }

        syncPanelTop();
        window.addEventListener("resize", syncPanelTop);
        window.addEventListener("scroll", syncPanelTop, { passive: true });

        function setOpen(next) {
          var prev = form.getAttribute("data-open") === "true";
          if (prev === next) return;
          form.setAttribute("data-open", next ? "true" : "false");
          btn.setAttribute("aria-expanded", next ? "true" : "false");
          if (next) {
            window.dispatchEvent(new CustomEvent("floatingPanelOpen", { detail: "search" }));
            syncPanelTop();
            setTimeout(function () { input.focus(); }, 80);
          } else {
            btn.focus();
          }
        }

        btn.addEventListener("click", function () {
          var open = form.getAttribute("data-open") === "true";
          setOpen(!open);
        });

        document.addEventListener("keydown", function (e) {
          if (e && e.key === "Escape") setOpen(false);
        });

        document.addEventListener("click", function (e) {
          var t = e && e.target;
          if (!t) return;
          var open = form.getAttribute("data-open") === "true";
          if (!open) return;
          if (btn.contains(t)) return;
          if (form.contains(t)) return;
          setOpen(false);
        });

        window.addEventListener("floatingPanelOpen", function (e) {
          var kind = e && e.detail;
          if (kind === "search") return;
          setOpen(false);
        });
      });
    })();
  </script>
</header>
