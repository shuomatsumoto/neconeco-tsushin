---
export type HomeLatestItem = {
  href: string;
  title: string;
  date: string;
  summary?: string;
  label: string;
  isPost: boolean;
  thumbnail?: string;
};

const { items, limit = 10, title = "最新の投稿", showTitle = true, showFeatured = true } = Astro.props as {
  items: HomeLatestItem[];
  limit?: number;
  title?: string;
  showTitle?: boolean;
  showFeatured?: boolean;
};

const shown = items.slice(0, limit);
const featured = showFeatured ? shown[0] : undefined;
const rest = showFeatured ? shown.slice(1) : shown;

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

function thumbSrc(raw?: string) {
  if (!raw) return null;
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  if (raw.startsWith("/")) return `${BASE}${raw.slice(1)}`;
  return `${BASE}${raw.replace(/^\/+/, "")}`;
}
---
<section class="homeLatest">
  {showTitle ? (
    <header class="head">
      <h2 class="h2" style="margin:0;">{title}</h2>
    </header>
  ) : null}

  <ul class="list">
    {featured ? (
      <li class="entry featuredEntry">
        {featured.isPost ? (
          <a class="featuredPost" href={featured.href}>
            {thumbSrc(featured.thumbnail) ? (
              <img class="featuredThumb post-thumb-wide" src={thumbSrc(featured.thumbnail) ?? ""} alt="" loading="lazy" />
            ) : null}
            <div class="postMain">
              <strong class="featuredTitle post-title-2line">{featured.title}</strong>
              <p class="postMeta">
                <span class="postLabel">{featured.label}</span>
                <span class="mono postDate">{featured.date}</span>
              </p>
              {featured.summary ? <p class="featuredSummary post-summary-2line">{featured.summary}</p> : null}
            </div>
          </a>
        ) : (
          <a class="featuredBand" href={featured.href}>
            <p class="featuredMeta">
              <span class="bandLabel">{featured.label}</span>
              <span class="bandDate mono">{featured.date}</span>
            </p>
            <strong class="featuredTitle">{featured.title}</strong>
            {featured.summary ? <p class="featuredSummary">{featured.summary}</p> : null}
          </a>
        )}
      </li>
    ) : null}

    {rest.map((item) => (
      <li class="entry">
        {item.isPost ? (
          <a class="postRow" href={item.href}>
            {thumbSrc(item.thumbnail) ? (
              <img class="thumb post-thumb-wide" src={thumbSrc(item.thumbnail) ?? ""} alt="" loading="lazy" />
            ) : null}
            <div class="postMain">
              <strong class="postTitle post-title-2line">{item.title}</strong>
              <p class="postMeta">
                <span class="postLabel">{item.label}</span>
                <span class="mono postDate">{item.date}</span>
              </p>
              {item.summary ? <p class="postSummary post-summary-2line">{item.summary}</p> : null}
            </div>
          </a>
        ) : (
          <a class="bandRow" href={item.href}>
            <span class="bandLabel">{item.label}</span>
            <span class="bandLine">{item.summary ? `${item.title} - ${item.summary}` : item.title}</span>
            <span class="bandDate mono">{item.date}</span>
          </a>
        )}
      </li>
    ))}
  </ul>
</section>

<style>
  .homeLatest {
    display: grid;
    gap: 10px;
  }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px dotted var(--line);
  }

  .entry {
    border-bottom: 1px dotted var(--line);
  }

  .featuredEntry {
    padding: 0 0 10px;
  }

  .featuredPost,
  .featuredBand {
    display: block;
    text-decoration: none;
    color: var(--ink);
    padding: 10px 0 0;
  }

  .featuredThumb {
    margin: 0 0 10px;
  }

  .featuredTitle {
    display: block;
    font-size: clamp(1.14rem, 2vw, 1.32rem);
    line-height: 1.32;
    font-weight: 500;
  }

  .featuredSummary {
    margin: 4px 0 0;
    font-size: 0.86rem;
    line-height: 1.5;
    color: var(--muted);
    opacity: 0.9;
  }

  .featuredMeta {
    margin: 0 0 4px;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .postRow {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 10px;
    text-decoration: none;
    color: var(--ink);
    padding: 9px 0;
  }

  .postRow:hover,
  .bandRow:hover {
    opacity: 0.84;
  }

  .thumb {
    margin: 0;
    min-height: 80px;
    height: 100%;
    object-fit: cover;
  }

  .postMain {
    min-width: 0;
  }

  .postTitle {
    display: block;
    font-size: 0.92rem;
    line-height: 1.35;
    font-weight: 400;
  }

  .postMeta {
    margin: 2px 0 0;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
    font-size: 0.72rem;
    color: var(--muted);
    opacity: 0.8;
  }

  .postLabel {
    white-space: nowrap;
  }

  .postDate {
    white-space: nowrap;
  }

  .postSummary {
    margin: 2px 0 0;
    font-size: 0.8rem;
    color: var(--muted);
    opacity: 0.86;
  }

  .bandRow {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) 88px;
    align-items: baseline;
    gap: 10px;
    padding: 9px 0;
    text-decoration: none;
    color: var(--ink);
  }

  .bandDate {
    font-size: 0.72rem;
    color: var(--muted);
    opacity: 0.8;
    white-space: nowrap;
    text-align: right;
  }

  .bandLine {
    font-size: 0.9rem;
    line-height: 1.35;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bandLabel {
    font-size: 0.74rem;
    color: var(--muted);
    opacity: 0.8;
    white-space: nowrap;
  }

  @media (max-width: 700px) {
    .postRow {
      grid-template-columns: 96px 1fr;
      gap: 8px;
    }

    .bandRow {
      grid-template-columns: 1fr;
      gap: 2px;
      padding: 8px 0;
    }

    .bandLine {
      white-space: normal;
      overflow: visible;
      text-overflow: clip;
    }

    .bandLabel {
      justify-self: start;
    }

    .bandDate {
      text-align: left;
    }
  }
</style>
