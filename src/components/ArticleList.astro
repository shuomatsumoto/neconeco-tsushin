---
import type { CollectionEntry } from "astro:content";
import { getContentSummary } from "../utils/content";

const { posts, limit, title = "記事" } = Astro.props as {
  posts: CollectionEntry<"posts">[];
  limit?: number;
  title?: string;
};

const shown = typeof limit === "number" ? posts.slice(0, limit) : posts;

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

function thumbSrc(raw?: string) {
  if (!raw) return null;
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  if (raw.startsWith("/")) return `${BASE}${raw.slice(1)}`;
  return `${BASE}${raw.replace(/^\/+/, "")}`;
}

---
<section class="plainSection">
  {title ? (
    <div class="sectionHead">
      <h2>{title}</h2>
    </div>
  ) : null}

  <ul class="postList">
    {shown.map((p) => {
      const summary = getContentSummary(p.data.summary, p.body ?? "");
      const t = thumbSrc((p.data as any).thumbnail as string | undefined);
      const tags = p.data.tags ?? [];

      return (
        <li>
          <a class="postCard" data-category={p.data.category} href={`${BASE}posts/${p.slug}`}>
            {t ? <img class="thumb post-thumb-wide" src={t} alt="" loading="lazy" /> : null}
            <div class="cardBody">
              <strong class="title post-title-2line">{p.data.title}</strong>
              <p class="date mono">{p.data.date}</p>
              {summary ? <p class="summary post-summary-2line">{summary}</p> : null}
              <div class="metaStack">
                {p.data.series ? <p class="seriesLine post-series-accent">〈{p.data.series}〉</p> : null}
                <div class="postMeta">
                  {p.data.category ? <span class="category">{p.data.category}</span> : null}
                  {tags.length ? <span class="tags">#{tags.join(" #")}</span> : null}
                </div>
              </div>
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .plainSection { padding: 0; margin: 0; }
  .sectionHead { margin: 0 0 8px; }
  .sectionHead h2 {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.15;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .postList {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }

  .postCard {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 12px;
    padding: 10px 0 12px;
    border-bottom: 1px dotted var(--line);
    text-decoration: none;
    color: var(--ink);
  }

  .thumb {
    aspect-ratio: 8 / 5;
    min-height: 80px;
    height: 100%;
    margin: 0;
    border: 0;
  }

  .postCard:hover {
    opacity: 0.82;
  }

  .cardBody {
    min-width: 0;
    display: grid;
    gap: 2px;
    align-content: start;
    padding: 0;
  }

  .postMeta {
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    font-size: var(--fs-list-meta);
    color: var(--muted);
    font-style: normal;
  }

  .title {
    display: block;
    font-size: 0.92rem;
    line-height: 1.35;
    color: var(--ink);
    font-weight: 400;
  }

  .summary {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--muted);
    opacity: 0.86;
  }

  .date {
    margin: 0;
    font-size: 0.68rem;
    color: var(--muted);
    opacity: 0.78;
    white-space: nowrap;
  }

  .seriesLine {
    margin: 0;
    font-size: 0.76rem;
    line-height: 1.2;
  }

  .metaStack {
    margin-top: 10px !important;
    padding-top: 0;
    display: grid;
    gap: 0;
  }

  .summary + .metaStack,
  .title + .metaStack {
    margin-top: 10px !important;
  }

  .category {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    min-width: 0;
    color: var(--muted);
  }

  .tags {
    margin: 0;
    color: var(--muted);
    opacity: 0.62;
    line-height: 1.4;
  }

  @media (max-width: 760px) {
    .postCard {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 8px;
    }
  }

  @media (max-width: 640px) {
    .postCard {
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 8px;
      padding: 9px 0;
    }

    .thumb {
      min-height: 72px;
    }
  }
</style>
