---
import type { CollectionEntry } from "astro:content";
import { getContentSummary } from "../utils/content";

const { posts, limit, title = "記事" } = Astro.props as {
  posts: CollectionEntry<"posts">[];
  limit?: number;
  title?: string;
};

const shown = typeof limit === "number" ? posts.slice(0, limit) : posts;

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

function thumbSrc(raw?: string) {
  if (!raw) return null;
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  if (raw.startsWith("/")) return `${BASE}${raw.slice(1)}`;
  return `${BASE}${raw.replace(/^\/+/, "")}`;
}

---
<section class="plainSection">
  {title ? (
    <div class="sectionHead">
      <h2>{title}</h2>
    </div>
  ) : null}

  <ul class="postList">
    {shown.map((p) => {
      const summary = getContentSummary(p.data.summary, p.body ?? "");
      const t = thumbSrc((p.data as any).thumbnail as string | undefined);

      return (
        <li>
          <a class="postCard" href={`${BASE}posts/${p.slug}`}>
            {t ? <img class="thumb post-thumb-wide" src={t} alt="" loading="lazy" /> : null}
            <div class="cardBody">
              <strong class="title post-title-2line">{p.data.title}</strong>
              <p class="date mono">{p.data.date}</p>
              {summary ? <p class="summary post-summary-2line">{summary}</p> : null}
            </div>
          </a>
        </li>
      );
    })}
  </ul>
</section>

<style>
  .plainSection { padding: 0; margin: 0; }
  .sectionHead { margin: 0 0 8px; }
  .sectionHead h2 {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.15;
    font-weight: 400;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .postList {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }

  .postCard {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 8px;
    padding: 10px 0 12px;
    border-bottom: 1px dotted var(--line);
    text-decoration: none;
    color: var(--ink);
  }

  .thumb {
    aspect-ratio: 8 / 5;
    width: 100%;
    height: auto;
    margin: 0;
    border: 0;
  }

  .postCard:hover {
    opacity: 0.82;
  }

  .cardBody {
    min-width: 0;
    display: grid;
    gap: 2px;
    align-content: start;
    padding: 0;
  }
  .title {
    display: block;
    font-size: 0.92rem;
    line-height: 1.35;
    color: var(--ink);
    font-weight: 400;
  }

  .summary {
    margin: 0;
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--muted);
    opacity: 0.86;
  }

  .date {
    margin: 0;
    font-size: 0.68rem;
    color: var(--muted);
    opacity: 0.78;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .postCard {
      padding: 9px 0;
    }
  }
</style>
