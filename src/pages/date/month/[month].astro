---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import LockGate from "../../../components/LockGate.astro";
import ListIndexHeader from "../../../components/ListIndexHeader.astro";
import { getDisplayTitle } from "../../../utils/content";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

function formatMonthLabel(value: string): string {
  const [year, month] = value.split("-");
  return `${Number(year)}年${Number(month)}月`;
}

async function sha256Hex(text: string): Promise<string> {
  const bytes = new TextEncoder().encode(text);
  const digest = await globalThis.crypto.subtle.digest("SHA-256", bytes);
  return Array.from(new Uint8Array(digest))
    .map((byte) => byte.toString(16).padStart(2, "0"))
    .join("");
}

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft && data.kind !== "note");
  const months = new Set<string>();

  for (const post of posts) {
    months.add(post.data.date.slice(0, 7));
  }

  return Array.from(months)
    .sort((a, b) => (a < b ? 1 : -1))
    .map((month) => ({ params: { month } }));
}

const { month } = Astro.params as { month: string };
const monthLabel = formatMonthLabel(month);

const posts = (await getCollection("posts", ({ data }) => !data.draft && data.kind !== "note"))
  .filter((post) => post.data.date.slice(0, 7) === month)
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const items = await Promise.all(
  posts.map(async (post) => {
    const { Content } = await post.render();
    const homeMore = String(post.body ?? "").includes("data-home-more");
    const lockHash = post.data.lockPasscode ? await sha256Hex(post.data.lockPasscode) : "";

    return {
      slug: post.slug,
      title: getDisplayTitle(post.data.title, post.data.date),
      date: post.data.date,
      Content,
      homeMore,
      lockHash,
      locked: !!post.data.locked,
      storageKey: `posts/${post.slug}`,
    };
  })
);

---
<BaseLayout title={`${monthLabel}の記事一覧 | ねこねこ通信`}>
  <section class="pageWrap">
    <ListIndexHeader title={`${monthLabel}の記事一覧`} countLabel={`${items.length}件`} />

    {items.length ? (
      <div class="monthArticleList">
        {items.map((post) => (
          <article class="monthArticle">
            <h2 class="recentTitle">
              <a class="recentTitleLink" href={`${BASE}posts/${post.slug}`}>
                {post.title}
              </a>
            </h2>
            <p class="recentDate mono">{post.date}</p>

            <LockGate locked={post.locked} lockHash={post.lockHash} storageKey={post.storageKey}>
              <div class="prose monthArticleBody" data-home-article-body>
                <post.Content />
              </div>
              {post.homeMore ? (
                <button class="homeMoreButton" type="button" hidden data-home-more-button>
                  つづきを表示
                </button>
              ) : null}
            </LockGate>
          </article>
        ))}
      </div>
    ) : (
      <p class="small">この月の記事はまだありません。</p>
    )}

    <p class="backLinkWrap">
      <a class="backLink" href={`${BASE}date/`}>月一覧へ戻る</a>
    </p>
  </section>

  <script is:inline>
    // @ts-nocheck
    function enhanceMonthArticles() {
      document.querySelectorAll("[data-home-article-body]").forEach((body) => {
        if (!(body instanceof HTMLElement)) return;
        const container = body.parentElement;
        if (!(container instanceof HTMLElement)) return;
        const button = container.querySelector("[data-home-more-button]");
        if (!(button instanceof HTMLButtonElement)) return;

        const marker = body.querySelector("[data-home-more]");
        if (!(marker instanceof HTMLElement)) {
          button.remove();
          return;
        }

        const more = document.createElement("div");
        more.className = "homeArticleMore";
        more.hidden = true;

        let hasMoreContent = false;
        let node = marker.nextSibling;
        while (node) {
          const next = node.nextSibling;
          more.appendChild(node);
          hasMoreContent = true;
          node = next;
        }

        marker.remove();

        if (!hasMoreContent) {
          button.remove();
          return;
        }

        body.appendChild(more);
        button.hidden = false;
        button.addEventListener("click", () => {
          more.hidden = false;
          button.remove();
        });
      });
    }

    enhanceMonthArticles();
  </script>
</BaseLayout>

<style>
  .pageWrap {
    width: min(100%, 940px);
    margin-inline: auto;
    display: grid;
    gap: 14px;
  }

  .monthArticleList {
    display: grid;
    gap: 28px;
  }

  .monthArticle {
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
  }

  .monthArticle:last-child {
    border-bottom: 0;
  }

  .recentTitle {
    margin: 0;
    font-size: clamp(1.38rem, 2.9vw, 1.86rem);
    line-height: 1.28;
    color: var(--accent);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Hiragino Sans",
      "Yu Gothic",
      "Noto Sans JP",
      sans-serif;
    font-weight: 400;
  }

  .recentTitleLink {
    color: inherit;
    text-decoration: none;
    display: inline-block;
    font: inherit;
  }

  .recentTitleLink:hover {
    opacity: 0.84;
  }

  .recentDate {
    margin: 6px 0 14px;
    color: var(--accent);
    font-size: 0.88rem;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Hiragino Sans",
      "Yu Gothic",
      "Noto Sans JP",
      sans-serif;
    font-weight: 400;
  }

  .monthArticleBody :global(p) {
    margin: 0 0 1.1em;
    font-size: 1rem;
    line-height: 1.8;
  }

  .monthArticleBody :global(h2),
  .monthArticleBody :global(h3),
  .monthArticleBody :global(h4),
  .monthArticleBody :global(h5),
  .monthArticleBody :global(h6) {
    margin: 1.4em 0 0.6em;
    font-weight: 500;
  }

  .monthArticleBody :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }

  .monthArticleBody :global(blockquote) {
    margin: 1.2em 0;
    padding: 12px 14px;
    border-left: 3px solid var(--line);
    background: rgba(255, 255, 255, 0.45);
    border-radius: 10px;
  }

  .homeMoreButton {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 0;
    margin: 8px 0 0;
    color: var(--accent);
    font-size: 0.95rem;
    line-height: 1.7;
    cursor: pointer;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Hiragino Sans",
      "Yu Gothic",
      "Noto Sans JP",
      sans-serif;
    font-weight: 400;
    text-decoration: none;
  }

  .homeMoreButton:hover {
    opacity: 0.82;
  }

  .homeMoreButton:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .homeArticleMore {
    margin-top: 0.8em;
  }

  .backLinkWrap {
    margin: 4px 0 0;
  }

  .backLink {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.94rem;
  }

  .backLink:hover {
    opacity: 0.84;
    text-decoration: underline;
  }
</style>
