---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getContentSummary } from "../utils/content";
import board from "../data/board.json";

function isNoteLike(data: { kind?: string }) {
  return data.kind === "note";
}

const postsAll = await getCollection(
  "posts",
  ({ data }) => !data.draft && !isNoteLike(data)
);
const posts = postsAll.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";
const latestPost = posts[0];
const todayYmd = new Intl.DateTimeFormat("en-CA", {
  timeZone: "Asia/Tokyo",
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(new Date());
const todayMonth = todayYmd.slice(0, 7);
const latestPostMonth = latestPost?.data.date.slice(0, 7) ?? "";
const latestBoardMonth = board
  .filter((item) => isYmd(item.date))
  .map((item) => item.date!.slice(0, 7))
  .sort((a, b) => (a < b ? 1 : -1))[0] ?? "";
const latestMonth = [todayMonth, latestPostMonth, latestBoardMonth]
  .filter(Boolean)
  .sort((a, b) => (a < b ? 1 : -1))[0] ?? "";

function thumbSrc(raw?: string) {
  if (!raw) return null;
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  if (raw.startsWith("/")) return `${BASE}${raw.slice(1)}`;
  return `${BASE}${raw.replace(/^\/+/, "")}`;
}

function isYmd(value: string | undefined) {
  return typeof value === "string" && /^\d{4}-\d{2}-\d{2}$/.test(value);
}

function formatShortDate(value: string) {
  const [, month, day] = value.split("-");
  return `${Number(month)}/${Number(day)}`;
}

function toDayNumber(value: string) {
  return Math.floor(Date.parse(`${value}T00:00:00+09:00`) / 86400000);
}

function shiftMonth(value: string, delta: number) {
  const base = new Date(`${value}-01T00:00:00+09:00`);
  base.setMonth(base.getMonth() + delta);
  const year = base.getFullYear();
  const month = String(base.getMonth() + 1).padStart(2, "0");
  return `${year}-${month}`;
}

function formatMonthLabel(value: string) {
  const [, month] = value.split("-");
  return `${Number(month)}月分を表示`;
}

type TimelineItem =
  | {
      kind: "post";
      date: string;
      href: string;
      title: string;
      summary: string;
      thumbnail?: string;
      category?: string;
      series?: string;
      tags: string[];
    }
  | {
      kind: "board";
      date: string;
      comment: string;
      href?: string;
    }
  | {
      kind: "todayMarker";
      date: string;
    };

function buildTimeline(month: string) {
  const monthPosts = month
    ? posts.filter((post) => post.data.date.startsWith(month))
    : [];
  const monthBoardItems = month
    ? board.filter((item) => isYmd(item.date) && item.date?.startsWith(month))
    : [];

  const timelineItems: TimelineItem[] = [
    ...monthPosts.map((post) => ({
      kind: "post" as const,
      date: post.data.date,
      href: `${BASE}posts/${post.slug}`,
      title: post.data.title,
      summary: getContentSummary(post.data.summary, post.body ?? ""),
      thumbnail: post.data.thumbnail,
      category: post.data.category,
      series: post.data.series,
      tags: post.data.tags ?? [],
    })),
    ...monthBoardItems.map((item) => ({
      kind: "board" as const,
      date: item.date ?? "",
      comment: item.comment ?? item.title ?? "",
      href: item.href,
    })),
  ];

  if (month === todayMonth && !timelineItems.some((item) => item.date === todayYmd)) {
    timelineItems.push({
      kind: "todayMarker" as const,
      date: todayYmd,
    });
  }

  return timelineItems.sort((a, b) => {
    if (a.date !== b.date) return a.date < b.date ? 1 : -1;
    if (a.kind === b.kind) return 0;
    if (a.kind === "todayMarker") return -1;
    if (b.kind === "todayMarker") return 1;
    return a.kind === "board" ? -1 : 1;
  }).map((item, index, items) => {
    if (index === 0) return { item, gapDots: 0, showBead: true };

    const previousItem = items[index - 1];
    const diff = Math.max(toDayNumber(previousItem.date) - toDayNumber(item.date), 0);

    return { item, gapDots: diff, showBead: previousItem.date !== item.date };
  });
}

const timelineWithGap = buildTimeline(latestMonth);
const previousMonth = latestMonth ? shiftMonth(latestMonth, -1) : "";
const previousTimelineWithGap = previousMonth ? buildTimeline(previousMonth) : [];
const previousMonthLabel = previousMonth ? formatMonthLabel(previousMonth) : "";
const crossMonthDots =
  timelineWithGap.length && previousTimelineWithGap.length
    ? Math.max(
        toDayNumber(timelineWithGap[timelineWithGap.length - 1].item.date) -
          toDayNumber(previousTimelineWithGap[0].item.date),
        0
      )
    : 0;

const leadPostIndex = timelineWithGap.findIndex(({ item }) => item.kind === "post");
const clientTimelineSource = {
  posts: posts.map((post) => ({
    date: post.data.date,
    href: `${BASE}posts/${post.slug}`,
    title: post.data.title,
    summary: getContentSummary(post.data.summary, post.body ?? ""),
    thumbnail: thumbSrc(post.data.thumbnail) ?? "",
    category: post.data.category ?? "",
    series: post.data.series ?? "",
    tags: post.data.tags ?? [],
  })),
  board: board
    .filter((item) => isYmd(item.date))
    .map((item) => ({
      date: item.date ?? "",
      comment: item.comment ?? item.title ?? "",
      href: item.href ?? "",
    })),
};
const serializedTimelineSource = JSON.stringify(clientTimelineSource).replace(/</g, "\\u003c");
---
<BaseLayout title="ねこねこ通信">
  <div class="homeGrid">
    <main class="homeCol">
      <section class="homeSection" id="homeTimeline">
        {timelineWithGap.length ? (
          <ul class="postGrid">
            {timelineWithGap.map(({ item, gapDots, showBead }, index) => {
              return (
              <li class="cardItem" style={`--dot-count:${gapDots};`}>
                {gapDots > 0 ? (
                  <span class="dotTrail" aria-hidden="true">
                    {Array.from({ length: gapDots }).map(() => (
                      <span class="trailDot"></span>
                    ))}
                  </span>
                ) : null}
                {showBead ? (
                  <span class="timeBead mono">
                    {formatShortDate(item.date)}
                  </span>
                ) : null}
                {item.kind === "post" ? (
                  <a class:list={["postCard", { isLeadPost: index === leadPostIndex }]} href={item.href}>
                    {item.thumbnail ? (
                      <div class="thumbFrame">
                        <img class="thumb post-thumb-wide" src={thumbSrc(item.thumbnail)} alt="" loading="lazy" />
                      </div>
                    ) : null}
                    <div class="cardBody">
                      <strong class="title post-title-2line">{item.title}</strong>
                      <div class="summaryWrap">
                        <p class="summary js-summary">{item.summary}</p>
                      </div>
                      <div class="cardFooter">
                        <div class="metaStack">
                          {item.series ? <p class="seriesLine post-series-accent">〈{item.series}〉</p> : null}
                          {item.category ? <p class="categoryLine"><span class="category">{item.category}</span></p> : null}
                        </div>
                      </div>
                    </div>
                  </a>
                ) : item.kind === "board" ? (
                  <div class="boardCard">
                    {item.href ? (
                      <a class="boardComment" href={item.href}>{item.comment}</a>
                    ) : (
                      <p class="boardComment">{item.comment}</p>
                    )}
                  </div>
                ) : (
                  <div class="todayMarkerCard" aria-label="今日">
                    <p class="todayMarkerText">今日はまだ記事がありません。</p>
                  </div>
                )}
              </li>
            )})}
          </ul>
        ) : null}
        {previousTimelineWithGap.length ? (
          <details class="olderMonths">
            <summary class="olderMonthsButton">{previousMonthLabel}</summary>
            {crossMonthDots > 0 ? (
              <div class="monthBridge" style={`--dot-count:${crossMonthDots};`} aria-hidden="true">
                <span class="dotTrail">
                  {Array.from({ length: crossMonthDots }).map(() => (
                    <span class="trailDot"></span>
                  ))}
                </span>
              </div>
            ) : null}
            <ul class="postGrid olderMonthsList">
              {previousTimelineWithGap.map(({ item, gapDots, showBead }) => (
                <li class="cardItem" style={`--dot-count:${gapDots};`}>
                  {gapDots > 0 ? (
                    <span class="dotTrail" aria-hidden="true">
                      {Array.from({ length: gapDots }).map(() => (
                        <span class="trailDot"></span>
                      ))}
                    </span>
                  ) : null}
                  {showBead ? (
                    <span class="timeBead mono">
                      {formatShortDate(item.date)}
                    </span>
                  ) : null}
                  {item.kind === "post" ? (
                    <a class="postCard" href={item.href}>
                      {item.thumbnail ? (
                        <div class="thumbFrame">
                          <img class="thumb post-thumb-wide" src={thumbSrc(item.thumbnail)} alt="" loading="lazy" />
                        </div>
                      ) : null}
                      <div class="cardBody">
                        <strong class="title post-title-2line">{item.title}</strong>
                        <div class="summaryWrap">
                          <p class="summary js-summary">{item.summary}</p>
                        </div>
                        <div class="cardFooter">
                          <div class="metaStack">
                            {item.series ? <p class="seriesLine post-series-accent">〈{item.series}〉</p> : null}
                            {item.category ? <p class="categoryLine"><span class="category">{item.category}</span></p> : null}
                          </div>
                        </div>
                      </div>
                    </a>
                  ) : item.kind === "board" ? (
                    <div class="boardCard">
                      {item.href ? (
                        <a class="boardComment" href={item.href}>{item.comment}</a>
                      ) : (
                        <p class="boardComment">{item.comment}</p>
                      )}
                    </div>
                  ) : (
                    <div class="todayMarkerCard" aria-label="今日">
                      <p class="todayMarkerText">今日はまだ記事がありません。</p>
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </details>
        ) : null}
      </section>
    </main>
  </div>

  <style>
    .homeGrid {
      width: min(100%, 940px);
      margin-inline: auto;
      display: grid;
      gap: 16px;
    }

    .homeCol {
      display: grid;
      gap: 16px;
      align-content: start;
      min-width: 0;
    }

    .homeSection {
      padding: 0;
      margin: 0;
    }

    .postGrid {
      --timeline-side-space: 34px;
      list-style: none;
      padding: 0;
      padding-right: var(--timeline-side-space);
      margin: 0;
      display: grid;
      gap: 0;
    }

    .olderMonths {
      margin-top: 18px;
    }

    .olderMonthsButton {
      cursor: pointer;
      font-size: 0.78rem;
      color: var(--muted);
      opacity: 0.62;
      list-style: none;
      user-select: none;
    }

    .olderMonthsButton::-webkit-details-marker {
      display: none;
    }

    .monthBridge {
      --dot-count: 0;
      --dot-step: 8px;
      --gap-space: calc(var(--dot-count) * var(--dot-step));
      --rail-x: 14px;
      position: relative;
      min-width: 0;
      height: var(--gap-space);
      padding-left: 34px;
      padding-right: 34px;
    }

    .monthBridge .dotTrail {
      left: var(--rail-x);
      height: var(--gap-space);
    }

    .olderMonthsList {
      margin-top: 0;
    }

    .cardItem {
      --dot-count: 0;
      --dot-step: 8px;
      --gap-space: calc(var(--dot-count) * var(--dot-step));
      --rail-x: 14px;
      position: relative;
      min-width: 0;
      padding-top: var(--gap-space);
      padding-left: 34px;
    }

    .dotTrail {
      position: absolute;
      left: var(--rail-x);
      top: 0;
      width: 3px;
      height: var(--gap-space);
      display: grid;
      grid-auto-rows: 2px;
      align-content: start;
      justify-items: center;
      gap: calc(var(--dot-step) - 2px);
      opacity: 0.72;
    }

    .trailDot {
      width: 3px;
      height: 2px;
      border-radius: 999px;
      background: rgba(122, 113, 98, 0.42);
    }

    .timeBead {
      position: absolute;
      left: calc(var(--rail-x) - 14px);
      top: calc(var(--gap-space) + 4px);
      z-index: 1;
      min-width: 40px;
      height: 24px;
      padding: 0 7px;
      border-radius: 999px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 0.68rem;
      line-height: 1;
      color: #5f564b;
      background: #eee8de;
      box-shadow: 0 0 0 1px rgba(98, 86, 67, 0.08);
      white-space: nowrap;
    }

    .postCard {
      --thumb-width: clamp(236px, 33vw, 320px);
      display: grid;
      grid-template-columns: var(--thumb-width) minmax(0, 1fr);
      gap: 16px;
      align-items: start;
      text-decoration: none;
      color: var(--ink);
      padding: 9px 11px 10px;
      transition: opacity 0.16s ease;
    }

    .postCard:hover {
      opacity: 0.82;
    }

    .postCard.isLeadPost {
      --thumb-width: 100%;
      grid-template-columns: minmax(0, 1fr);
      gap: 8px;
    }

    .thumbFrame {
      width: 100%;
      aspect-ratio: 8 / 5;
      overflow: hidden;
      align-self: start;
    }

    .thumb {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      margin: 0;
      border: 0;
    }

    .cardBody {
      min-width: 0;
      display: flex;
      flex-direction: column;
      padding: 0;
      height: calc(var(--thumb-width) * 5 / 8);
      max-height: calc(var(--thumb-width) * 5 / 8);
      min-height: calc(var(--thumb-width) * 5 / 8);
      overflow: hidden;
    }

    .postCard.isLeadPost .cardBody {
      height: auto;
      max-height: none;
      min-height: 0;
    }

    .title {
      display: block;
      font-size: 1.08rem;
      line-height: 1.4;
      color: var(--ink);
      font-weight: 400;
      overflow: visible;
      display: block;
      -webkit-line-clamp: unset;
      -webkit-box-orient: initial;
    }

    .seriesLine {
      margin: 0;
      font-size: 0.8rem;
      line-height: 1.2;
      color: #5f564b;
      opacity: 0.88;
    }

    .summary {
      margin: 0;
      font-size: 0.88rem;
      line-height: 1.65;
      color: var(--muted);
      opacity: 0.9;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: var(--summary-lines, 2);
      overflow: hidden;
    }

    .summaryWrap {
      flex: 1 1 auto;
      min-height: 0;
      padding-top: 2px;
    }

    .cardFooter {
      margin-top: 8px;
      flex: 0 0 auto;
    }

    .metaStack {
      display: grid;
      gap: 2px;
    }

    .categoryLine {
      margin: auto 0 0;
      font-size: 0.8rem;
      color: var(--muted);
      opacity: 0.88;
    }

    .category {
      display: inline-flex;
      gap: 4px;
      align-items: center;
      min-width: 0;
    }

    .boardCard {
      padding: 9px 11px 10px;
      display: grid;
      gap: 4px;
    }

    .todayMarkerCard {
      padding: 10px 11px 12px;
    }

    .todayMarkerText {
      margin: 0;
      font-size: 0.84rem;
      line-height: 1.5;
      color: var(--muted);
      opacity: 0.8;
    }

    .boardComment {
      margin: 0;
      font-size: 0.94rem;
      line-height: 1.6;
      color: var(--muted);
      text-decoration: none;
      opacity: 0.92;
    }

    a.boardComment:hover {
      opacity: 0.84;
    }

    @media (max-width: 900px) {
      .homeGrid {
        gap: 18px;
      }
    }

    @media (max-width: 760px) {
      .postGrid {
        --timeline-side-space: 28px;
      }

      .cardItem {
        --dot-step: 7px;
      }

      .monthBridge {
        --dot-step: 7px;
        padding-left: 28px;
        padding-right: 28px;
      }

      .postCard {
        --thumb-width: clamp(208px, 36vw, 248px);
        gap: 10px;
      }

    }

    @media (max-width: 640px) {
      .postGrid {
        --timeline-side-space: 22px;
      }

      .cardItem {
        --dot-step: 6px;
      }

      .monthBridge {
        --dot-step: 6px;
        padding-left: 22px;
        padding-right: 22px;
      }

      .postCard {
        --thumb-width: 100%;
        grid-template-columns: minmax(0, 1fr);
        gap: 8px;
        padding: 9px 10px 10px;
      }

      .cardBody {
        height: auto;
        max-height: none;
        min-height: 0;
      }

      .summary {
        -webkit-line-clamp: 3;
      }

      .categoryLine {
        font-size: 0.74rem;
      }

      .seriesLine {
        font-size: 0.74rem;
      }
    }
  </style>
  <script>
    function fitHomeSummaries() {
      document.querySelectorAll(".summaryWrap").forEach((wrap) => {
        const summary = wrap.querySelector(".js-summary");
        if (!(summary instanceof HTMLElement) || !(wrap instanceof HTMLElement)) return;
        const wrapHeight = wrap.clientHeight;
        const lineHeight = Number.parseFloat(getComputedStyle(summary).lineHeight);
        const lines = Math.max(1, Math.floor(wrapHeight / lineHeight));
        summary.style.setProperty("--summary-lines", String(lines));
      });
    }

    function renderHomeTimeline() {
      const root = document.getElementById("homeTimeline");
      if (!(root instanceof HTMLElement)) return;

      const source = JSON.parse('{serializedTimelineSource}');

      function isYmd(value) {
        return typeof value === "string" && /^\d{4}-\d{2}-\d{2}$/.test(value);
      }

      function getTokyoYmd() {
        return new Intl.DateTimeFormat("en-CA", {
          timeZone: "Asia/Tokyo",
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
        }).format(new Date());
      }

      function toDayNumber(value) {
        return Math.floor(Date.parse(`${value}T00:00:00+09:00`) / 86400000);
      }

      function shiftMonth(value, delta) {
        const base = new Date(`${value}-01T00:00:00+09:00`);
        base.setMonth(base.getMonth() + delta);
        const year = base.getFullYear();
        const month = String(base.getMonth() + 1).padStart(2, "0");
        return `${year}-${month}`;
      }

      function formatShortDate(value) {
        const [, month, day] = value.split("-");
        return `${Number(month)}/${Number(day)}`;
      }

      function formatMonthLabel(value) {
        const [, month] = value.split("-");
        return `${Number(month)}月分を表示`;
      }

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }

      function buildTimeline(month, todayYmd, todayMonth) {
        const monthPosts = month
          ? source.posts
              .filter((post) => post.date.startsWith(month))
              .map((post) => ({ kind: "post", ...post }))
          : [];
        const monthBoardItems = month
          ? source.board
              .filter((item) => isYmd(item.date) && item.date.startsWith(month))
              .map((item) => ({ kind: "board", ...item }))
          : [];

        const items = [...monthPosts, ...monthBoardItems];

        if (month === todayMonth && !items.some((item) => item.date === todayYmd)) {
          items.push({ kind: "todayMarker", date: todayYmd });
        }

        return items
          .sort((a, b) => {
            if (a.date !== b.date) return a.date < b.date ? 1 : -1;
            if (a.kind === b.kind) return 0;
            if (a.kind === "todayMarker") return -1;
            if (b.kind === "todayMarker") return 1;
            return a.kind === "board" ? -1 : 1;
          })
          .map((item, index, sorted) => {
            if (index === 0) return { item, gapDots: 0, showBead: true };
            const previousItem = sorted[index - 1];
            const diff = Math.max(toDayNumber(previousItem.date) - toDayNumber(item.date), 0);
            return { item, gapDots: diff, showBead: previousItem.date !== item.date };
          });
      }

      function renderDots(count) {
        if (count <= 0) return "";
        return `<span class="dotTrail" aria-hidden="true">${Array.from({ length: count }, () => '<span class="trailDot"></span>').join("")}</span>`;
      }

      function renderItem(entry, index, leadPostIndex) {
        const { item, gapDots, showBead } = entry;
        const bead = showBead
          ? `<span class="timeBead mono">${formatShortDate(item.date)}</span>`
          : "";

        let body = "";
        if (item.kind === "post") {
          body = `
            <a class="postCard${index === leadPostIndex ? " isLeadPost" : ""}" href="${escapeHtml(item.href)}">
              ${item.thumbnail ? `<div class="thumbFrame"><img class="thumb post-thumb-wide" src="${escapeHtml(item.thumbnail)}" alt="" loading="lazy" /></div>` : ""}
              <div class="cardBody">
                <strong class="title post-title-2line">${escapeHtml(item.title)}</strong>
                <div class="summaryWrap">
                  <p class="summary js-summary">${escapeHtml(item.summary)}</p>
                </div>
                <div class="cardFooter">
                  <div class="metaStack">
                    ${item.series ? `<p class="seriesLine post-series-accent">〈${escapeHtml(item.series)}〉</p>` : ""}
                    ${item.category ? `<p class="categoryLine"><span class="category">${escapeHtml(item.category)}</span></p>` : ""}
                  </div>
                </div>
              </div>
            </a>`;
        } else if (item.kind === "board") {
          body = item.href
            ? `<div class="boardCard"><a class="boardComment" href="${escapeHtml(item.href)}">${escapeHtml(item.comment)}</a></div>`
            : `<div class="boardCard"><p class="boardComment">${escapeHtml(item.comment)}</p></div>`;
        } else {
          body = `<div class="todayMarkerCard" aria-label="今日"><p class="todayMarkerText">今日はまだ記事がありません。</p></div>`;
        }

        return `<li class="cardItem" style="--dot-count:${gapDots};">${renderDots(gapDots)}${bead}${body}</li>`;
      }

      const todayYmd = getTokyoYmd();
      const todayMonth = todayYmd.slice(0, 7);
      const latestPostMonth = source.posts.map((post) => post.date.slice(0, 7)).sort((a, b) => (a < b ? 1 : -1))[0] ?? "";
      const latestBoardMonth = source.board.map((item) => item.date.slice(0, 7)).sort((a, b) => (a < b ? 1 : -1))[0] ?? "";
      const latestMonth = [todayMonth, latestPostMonth, latestBoardMonth]
        .filter(Boolean)
        .sort((a, b) => (a < b ? 1 : -1))[0] ?? "";

      const currentTimeline = buildTimeline(latestMonth, todayYmd, todayMonth);
      const previousMonth = latestMonth ? shiftMonth(latestMonth, -1) : "";
      const previousTimeline = previousMonth ? buildTimeline(previousMonth, todayYmd, todayMonth) : [];
      const crossMonthDots =
        currentTimeline.length && previousTimeline.length
          ? Math.max(
              toDayNumber(currentTimeline[currentTimeline.length - 1].item.date) -
                toDayNumber(previousTimeline[0].item.date),
              0
            )
          : 0;
      const leadPostIndex = currentTimeline.findIndex((entry) => entry.item.kind === "post");

      root.innerHTML = `
        ${currentTimeline.length ? `<ul class="postGrid">${currentTimeline.map((entry, index) => renderItem(entry, index, leadPostIndex)).join("")}</ul>` : ""}
        ${previousTimeline.length ? `
          <details class="olderMonths">
            <summary class="olderMonthsButton">${formatMonthLabel(previousMonth)}</summary>
            ${crossMonthDots > 0 ? `<div class="monthBridge" style="--dot-count:${crossMonthDots};" aria-hidden="true">${renderDots(crossMonthDots)}</div>` : ""}
            <ul class="postGrid olderMonthsList">${previousTimeline.map((entry) => renderItem(entry, -1, -1)).join("")}</ul>
          </details>` : ""}
      `;
    }

    renderHomeTimeline();
    fitHomeSummaries();
    window.addEventListener("resize", fitHomeSummaries);
  </script>
</BaseLayout>
