---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import Calendar from "../components/Calendar.astro";
import HomeArticleBlock from "../components/HomeArticleBlock.astro";
import type { HomeLatestItem } from "../components/HomeArticleBlock.astro";
import { getContentSummary } from "../utils/content";
import board from "../data/board.json";
import memorials from "../data/memorials.json";
import NoticeList from "../components/NoticeList.astro";

function isNoteLike(data: { kind?: string }) {
  return data.kind === "note";
}

const postsAll = await getCollection(
  "posts",
  ({ data }) => !data.draft && !isNoteLike(data)
);
const posts = postsAll.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

const latestArticleItems: HomeLatestItem[] = posts
  .map((p) => ({
    href: `${BASE}posts/${p.slug}`,
    title: p.data.title,
    date: p.data.date,
    summary: getContentSummary(p.data.summary, p.body ?? ""),
    isPost: true,
    thumbnail: p.data.thumbnail,
    category: p.data.category,
    series: p.data.series,
  }))
  .sort((a, b) => {
    if (a.date !== b.date) return a.date < b.date ? 1 : -1;
    return a.href < b.href ? 1 : -1;
  });

function isYmd(value: string | undefined) {
  return typeof value === "string" && /^\d{4}-\d{2}-\d{2}$/.test(value);
}

const boardItems = [...board].sort((a, b) => {
  const aDate = a.date ?? "";
  const bDate = b.date ?? "";
  const aIsYmd = isYmd(aDate);
  const bIsYmd = isYmd(bDate);

  if (aIsYmd && bIsYmd) return aDate < bDate ? 1 : -1;
  if (aIsYmd) return -1;
  if (bIsYmd) return 1;
  return aDate.localeCompare(bDate, "ja");
});
---
<BaseLayout title="ねこねこ通信">
  <div class="homeGrid">
    <main class="homeCol">
      <section class="homeSection">
        <HomeArticleBlock items={latestArticleItems} limit={6} loadMoreStep={6} showTitle={false} />
      </section>
    </main>

    <aside class="homeCol homeAside">
      <section class="homeSection">
        <NoticeList notices={boardItems} title="ボード" limit={16} />
      </section>

      <section class="homeSection">
        <Calendar posts={posts} memorials={memorials} />
      </section>
    </aside>
  </div>

  <style>
    .homeGrid {
      display: grid;
      grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
      gap: 26px;
      align-items: start;
      justify-content: center;
    }

    .homeCol {
      display: grid;
      gap: 16px;
      align-content: start;
      min-width: 0;
    }

    .homeSection {
      padding: 0;
      margin: 0;
    }

    @media (max-width: 900px) {
      .homeGrid {
        grid-template-columns: 1fr;
        gap: 18px;
      }
    }

  </style>
</BaseLayout>
