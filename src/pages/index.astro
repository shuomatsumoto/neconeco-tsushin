---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import LockGate from "../components/LockGate.astro";
import { getDisplayTitle } from "../utils/content";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

type PostEntry = CollectionEntry<"posts">;

type HomePostItem = {
  slug: string;
  title: string;
  date: string;
  month: string;
  searchable: string;
  visible: boolean;
  Content: Awaited<ReturnType<PostEntry["render"]>>["Content"];
  homeMore: boolean;
  lockHash: string;
  locked: boolean;
  storageKey: string;
};

type MonthArchiveEntry = {
  month: string;
  label: string;
  count: number;
};

async function sha256Hex(text: string): Promise<string> {
  const bytes = new TextEncoder().encode(text);
  const digest = await globalThis.crypto.subtle.digest("SHA-256", bytes);
  return Array.from(new Uint8Array(digest))
    .map((byte) => byte.toString(16).padStart(2, "0"))
    .join("");
}

function formatMonthLabel(value: string): string {
  const [year, month] = value.split("-");
  return `${Number(year)}年${Number(month)}月`;
}

function normalizeSearchText(value: string): string {
  return value.toLowerCase().replace(/\s+/g, " ").trim();
}

function tokenizeSearchQuery(value: string): string[] {
  return normalizeSearchText(value).split(" ").filter(Boolean);
}

const posts = (await getCollection("posts", ({ data }) => !data.draft && data.kind === "cahier")).sort(
  (a, b) => (a.data.date < b.data.date ? 1 : -1)
);

const monthArchiveMap = new Map<string, number>();
for (const post of posts) {
  const month = post.data.date.slice(0, 7);
  monthArchiveMap.set(month, (monthArchiveMap.get(month) ?? 0) + 1);
}

const monthArchiveEntries: MonthArchiveEntry[] = Array.from(monthArchiveMap, ([month, count]) => ({
  month,
  label: formatMonthLabel(month),
  count,
})).sort((a, b) => (a.month < b.month ? 1 : -1));

const requestedMonth = Astro.url.searchParams.get("month") ?? "";
const requestedSearch = Astro.url.searchParams.get("search") ?? "";
const searchQuery = requestedSearch.trim();
const defaultMonth = monthArchiveEntries[0]?.month ?? "";
const selectedMonth = monthArchiveEntries.some((entry) => entry.month === requestedMonth)
  ? requestedMonth
  : defaultMonth;

const selectedMonthEntry = monthArchiveEntries.find((entry) => entry.month === selectedMonth);

const selectedMonthPosts = posts.filter((post) => post.data.date.slice(0, 7) === selectedMonth);

const searchableText = (post: PostEntry) =>
  normalizeSearchText(
    [getDisplayTitle(post.data.title, post.data.date), post.data.title ?? "", post.body ?? "", post.slug].join(" ")
  );

const searchTerms = tokenizeSearchQuery(searchQuery);
const initialVisibleSlugs = new Set(
  searchTerms.length
    ? posts
        .filter((post) => {
          const text = searchableText(post);
          return searchTerms.every((term) => text.includes(term));
        })
        .map((post) => post.slug)
    : selectedMonthPosts.map((post) => post.slug)
);

const displayPosts = await Promise.all(
  posts.map(async (post) => {
    const { Content } = await post.render();
    const homeMore = String(post.body ?? "").includes("data-home-more");
    const lockHash = post.data.lockPasscode ? await sha256Hex(post.data.lockPasscode) : "";
    const searchable = searchableText(post);
    const month = post.data.date.slice(0, 7);

    return {
      slug: post.slug,
      title: getDisplayTitle(post.data.title, post.data.date),
      date: post.data.date,
      month,
      searchable,
      visible: initialVisibleSlugs.has(post.slug),
      Content,
      homeMore,
      lockHash,
      locked: !!post.data.locked,
      storageKey: `posts/${post.slug}`,
    } satisfies HomePostItem;
  })
);
---
<BaseLayout title="ねこねこ通信">
  <main class="homePage">
    <section class="homeSection" data-home-root data-selected-month={selectedMonth}>

      <p class="small" data-home-search-empty hidden>
        「{searchQuery}」に一致するカイエはありません。
      </p>
      <p class="small" data-home-month-empty hidden>この月のカイエはまだありません。</p>

      <div class="homeRecentList">
        {displayPosts.map((post) => (
          <article
            class="homeRecentArticle"
            data-home-post
            data-home-post-month={post.month}
            data-home-post-searchable={post.searchable}
            hidden={!post.visible}
          >
            <h2 class="recentTitle">
              <a class="recentTitleLink" href={`${BASE}posts/${post.slug}`}>
                {post.title}
              </a>
            </h2>
            <p class="recentDate mono">{post.date}</p>

            <LockGate locked={post.locked} lockHash={post.lockHash} storageKey={post.storageKey}>
              <div class="prose homeArticleBody" data-home-article-body>
                <post.Content />
              </div>
              {post.homeMore ? (
                <button class="homeMoreButton" type="button" hidden data-home-more-button>
                  つづきを表示
                </button>
              ) : null}
            </LockGate>
          </article>
        ))}
      </div>

      <hr class="homeDivider" />

      {monthArchiveEntries.length ? (
        <nav class="monthPicker" aria-label="月の一覧">
          <div class="homeSearch homeSearch--inMonth">
            <input
              class="homeSearchInput"
              type="search"
              name="search"
              value={searchQuery}
              placeholder="検索"
              aria-label="検索"
              enterkeyhint="search"
              data-home-search-input
            />
          </div>
          <ul class="monthArchiveList">
            {monthArchiveEntries.map((entry) => (
              <li class="monthArchiveItem">
                <a
                  class={`monthArchiveLink${entry.month === selectedMonth ? " isCurrent" : ""}`}
                  href={`?month=${entry.month}`}
                  aria-current={entry.month === selectedMonth ? "page" : undefined}
                  data-home-month-link
                  data-home-month={entry.month}
                >
                  {entry.label} ({entry.count})
                </a>
              </li>
            ))}
          </ul>
        </nav>
      ) : null}
    </section>
  </main>

  <style>
    .homePage {
      width: min(100%, 1040px);
      margin-inline: auto;
      display: grid;
      gap: 18px;
    }

    .homeSection {
      display: grid;
      gap: 14px;
      min-width: 0;
    }

    .homeSearch {
      width: min(100%, 220px);
      justify-self: start;
      margin-inline: 0;
    }

    .homeSearch--inMonth {
      justify-self: end;
      margin-bottom: 6px;
    }

    .homeSearchInput {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 0;
      background: rgba(255, 255, 255, 0.48);
      color: var(--ink);
      padding: 8px 10px;
      font: inherit;
    }

    .homeSearchInput:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .homeDivider {
      border: 0;
      border-top: 1px solid var(--line);
      margin: 32px 0 56px;
    }

    .monthPicker {
      display: grid;
      gap: 8px;
      margin-top: 48px;
      position: relative;
      border-top: 1px solid transparent;
    }

    .monthPicker::after {
      content: "";
      display: block;
      margin-top: 18px;
      border-top: 1px solid var(--line);
      margin-bottom: 18px;
    }

    @media (min-width: 641px) {
      .monthPicker .homeSearch--inMonth {
        position: absolute;
        top: -8px;
        left: 0;
      }
    }

    .monthArchiveList {
      margin-top: 72px;
      margin-bottom: 0;
    }

    .monthArchiveList {
      list-style: none;
      padding: 0;
      display: grid;
      gap: 0.35rem;
    }

    .monthArchiveLink {
      color: #2f7d4f;
      text-decoration: none;
    }

    .monthArchiveLink:hover {
      opacity: 0.84;
    }

    .monthArchiveLink.isCurrent {
      color: #2f7d4f;
    }

    .homeRecentList {
      display: grid;
      width: min(100%, 860px);
      margin-inline: auto;
      gap: 28px;
      margin-bottom: 6px;
    }

    .homeRecentArticle {
      padding: 18px 0;
      border-bottom: 1px solid var(--line);
    }

    .homeRecentArticle:last-child {
      border-bottom: 0;
    }

    .recentTitle {
      margin: 0;
      font-size: clamp(1.38rem, 2.9vw, 1.86rem);
      line-height: 1.28;
      color: var(--accent);
      font-family:
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Hiragino Sans",
        "Yu Gothic",
        "Noto Sans JP",
        sans-serif;
      font-weight: 400;
    }

    .recentTitleLink {
      color: inherit;
      text-decoration: none;
      display: inline-block;
      font: inherit;
    }

    .recentTitleLink:hover {
      opacity: 0.84;
    }

    .recentDate {
      margin: 6px 0 14px;
      color: var(--accent);
      font-size: 0.88rem;
      font-family:
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Hiragino Sans",
        "Yu Gothic",
        "Noto Sans JP",
        sans-serif;
      font-weight: 400;
    }

    .prose :global(p) {
      margin: 0 0 1.1em;
      font-size: 1rem;
      line-height: 1.8;
    }

    .prose :global(h2),
    .prose :global(h3),
    .prose :global(h4),
    .prose :global(h5),
    .prose :global(h6) {
      margin: 1.4em 0 0.6em;
      font-weight: 500;
    }

    .prose :global(a) {
      color: var(--accent);
      text-decoration: underline;
    }

    .homeMoreButton {
      appearance: none;
      background: transparent;
      border: 0;
      padding: 0;
      margin: 8px 0 0;
      color: var(--accent);
      font-size: 0.95rem;
      line-height: 1.7;
      cursor: pointer;
      font-family:
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Hiragino Sans",
        "Yu Gothic",
        "Noto Sans JP",
        sans-serif;
      font-weight: 400;
      text-decoration: none;
    }

    .homeMoreButton:hover {
      opacity: 0.82;
    }

    .homeMoreButton:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 3px;
      border-radius: 2px;
    }

    .prose :global(blockquote) {
      margin: 1.2em 0;
      padding: 12px 14px;
      border-left: 3px solid var(--line);
      background: rgba(255, 255, 255, 0.45);
      border-radius: 10px;
    }

    @media (max-width: 640px) {
      .homeRecentList {
        gap: 22px;
      }

      .monthPicker .homeSearch--inMonth {
        position: static;
        justify-self: start;
        margin-bottom: 12px;
      }
    }
  </style>

  <script is:inline>
    // @ts-nocheck
    function normalizeSearchText(value) {
      return value.toLowerCase().replace(/\s+/g, " ").trim();
    }

    function tokenizeSearchQuery(value) {
      return normalizeSearchText(value).split(" ").filter(Boolean);
    }

    function enhanceHomeArticles() {
      document.querySelectorAll("[data-home-article-body]").forEach((body) => {
        if (!(body instanceof HTMLElement)) return;
        const container = body.parentElement;
        if (!(container instanceof HTMLElement)) return;
        const button = container.querySelector("[data-home-more-button]");
        if (!(button instanceof HTMLButtonElement)) return;

        const marker = body.querySelector("[data-home-more]");
        if (!(marker instanceof HTMLElement)) {
          button.remove();
          return;
        }

        const more = document.createElement("div");
        more.className = "homeArticleMore";
        more.hidden = true;

        let hasMoreContent = false;
        let node = marker.nextSibling;
        while (node) {
          const next = node.nextSibling;
          more.appendChild(node);
          hasMoreContent = true;
          node = next;
        }

        marker.remove();

        if (!hasMoreContent) {
          button.remove();
          return;
        }

        body.appendChild(more);
        button.hidden = false;
        button.addEventListener("click", () => {
          more.hidden = false;
          button.remove();
        });
      });
    }

    function enhanceLiveSearch() {
      const root = document.querySelector("[data-home-root]");
      const input = document.querySelector("[data-home-search-input]");
      const articles = Array.from(document.querySelectorAll("[data-home-post]"));
      const monthLinks = Array.from(document.querySelectorAll("[data-home-month-link]"));
      const searchEmpty = document.querySelector("[data-home-search-empty]");
      const monthEmpty = document.querySelector("[data-home-month-empty]");

      if (
        !(root instanceof HTMLElement) ||
        !(input instanceof HTMLInputElement) ||
        !(searchEmpty instanceof HTMLElement) ||
        !(monthEmpty instanceof HTMLElement)
      ) {
        return;
      }

      const defaultMonth = root.dataset.selectedMonth ?? "";
      const availableMonths = new Set(
        monthLinks
          .filter((link) => link instanceof HTMLElement)
          .map((link) => link.dataset.homeMonth ?? "")
          .filter(Boolean)
      );
      const params = new URLSearchParams(window.location.search);
      const urlMonth = params.get("month") ?? "";
      const selectedMonth = availableMonths.has(urlMonth) ? urlMonth : defaultMonth;
      const urlSearch = params.get("search");

      if (urlSearch !== null) {
        input.value = urlSearch;
      }

      for (const link of monthLinks) {
        if (!(link instanceof HTMLAnchorElement)) continue;

        const isCurrent = link.dataset.homeMonth === selectedMonth;
        link.classList.toggle("isCurrent", isCurrent);

        if (isCurrent) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      }

      const applyFilter = () => {
        const terms = tokenizeSearchQuery(input.value);
        const isSearching = terms.length > 0;
        let visibleCount = 0;

        for (const article of articles) {
          if (!(article instanceof HTMLElement)) continue;

          const searchable = normalizeSearchText(article.dataset.homePostSearchable ?? "");
          const month = article.dataset.homePostMonth ?? "";
          const visible = isSearching ? terms.every((term) => searchable.includes(term)) : month === selectedMonth;

          article.hidden = !visible;
          if (visible) visibleCount += 1;
        }

        searchEmpty.hidden = !isSearching || visibleCount > 0;
        monthEmpty.hidden = isSearching || visibleCount > 0;
      };

      input.addEventListener("input", applyFilter);
      applyFilter();
    }

    enhanceHomeArticles();
    enhanceLiveSearch();
  </script>
</BaseLayout>
