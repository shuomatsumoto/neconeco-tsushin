---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { studySeriesMap } from "../../../data/study-series";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

export async function getStaticPaths() {
  const items = await getCollection("studyConcepts", ({ data }) => !data.draft);
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const studyUnit = studySeriesMap.get(item.data.seriesSlug);
---
<BaseLayout title={`${item.data.title} | ねこねこ研究所`}>
  <article class="plainArticle">
    {studyUnit ? (
      <p class="studyUnitLine">
        <a href={`${BASE}study/series/${studyUnit.slug}`}>{studyUnit.title}</a>
      </p>
    ) : null}
    <h1 class="h1">{item.data.title}</h1>
    {item.data.summary ? <p class="summaryLead">{item.data.summary}</p> : null}
    {item.data.plans?.length ? (
      <ul class="planList">
        {item.data.plans.map((plan) => (
          <li>{plan}</li>
        ))}
      </ul>
    ) : null}
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .plainArticle {
    padding: 0;
    margin: 0;
    padding-top: 15px;
    max-width: 760px;
    margin-inline: auto;
  }

  .studyUnitLine {
    margin: 0 0 8px;
    font-size: 0.8rem;
    color: var(--muted);
  }

  .studyUnitLine a {
    color: inherit;
    text-decoration: none;
  }

  .studyUnitLine a:hover {
    opacity: 0.78;
  }

  .plainArticle .h1 {
    font-size: clamp(1.45rem, 2.7vw, 1.82rem);
    line-height: 1.38;
    margin: 0 0 8px;
  }

  .summaryLead {
    margin: 0 0 14px;
    color: var(--muted);
    opacity: 0.86;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .planList {
    margin: 0 0 16px;
    padding-left: 1.2rem;
    display: grid;
    gap: 4px;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.6;
  }

  .prose :global(p) {
    margin: 0 0 1.05em;
    font-size: 1rem;
    line-height: 1.7;
  }
</style>
