---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import BandList, { type BandItem } from "../../components/BandList.astro";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

const translationItems = await getCollection("translation", ({ data }) => !data.draft);
const researchItems = await getCollection("research", ({ data }) => !data.draft);

const seen = new Set<string>();
const merged = [...translationItems, ...researchItems].filter((item) => {
  const key = `${item.collection}:${item.slug}`;
  if (seen.has(key)) return false;
  seen.add(key);
  return true;
});

const items: BandItem[] = merged
  .map((item) => ({
    href: `${BASE}study/${item.slug}`,
    title: item.data.title,
    date: item.data.date,
    summary: item.data.summary ?? "",
  }))
  .sort((a, b) => {
    if (a.date !== b.date) return a.date < b.date ? 1 : -1;
    return a.href < b.href ? 1 : -1;
  });
---
<BaseLayout title="研究・翻訳 | かもねぎ通信">
  <section class="pageWrap">
    <BandList items={items} title="研究・翻訳" emptyText="研究・翻訳の投稿はまだありません。" />
  </section>
</BaseLayout>

<style>
  .pageWrap {
    width: min(100%, 940px);
    margin-inline: auto;
  }
</style>
