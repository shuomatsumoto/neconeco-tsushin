---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { studySeriesList } from "../../data/study-series";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

function thumbSrc(raw?: string) {
  if (!raw) return null;
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  if (raw.startsWith("/")) return `${BASE}${raw.slice(1)}`;
  return `${BASE}${raw.replace(/^\/+/, "")}`;
}

const [translationItems, researchItems, novelItems] = await Promise.all([
  getCollection("translation", ({ data }) => !data.draft),
  getCollection("research", ({ data }) => !data.draft),
  getCollection("novel", ({ data }) => !data.draft),
]);
const conceptItems = await getCollection("studyConcepts", ({ data }) => !data.draft);

const seriesTranslationItems = translationItems.filter((item) => Boolean(item.data.studySeries));
const seriesResearchItems = researchItems.filter((item) => Boolean(item.data.studySeries));
const seriesNovelItems = novelItems.filter((item) => Boolean(item.data.studySeries));

const unitCounts = new Map<string, number>();
for (const item of [...seriesTranslationItems, ...seriesResearchItems, ...seriesNovelItems]) {
  const slug = item.data.studySeries;
  if (!slug) continue;
  unitCounts.set(slug, (unitCounts.get(slug) ?? 0) + 1);
}
for (const item of conceptItems) {
  const slug = item.data.seriesSlug;
  unitCounts.set(slug, (unitCounts.get(slug) ?? 0) + 1);
}

const studyUnits = studySeriesList
  .map((series) => ({
    ...series,
    href: `${BASE}study/series/${series.slug}`,
    thumb: thumbSrc(series.thumbnail),
    count: (unitCounts.get(series.slug) ?? 0) + 1,
  }));

const storageCount =
  translationItems.filter((item) => !item.data.studySeries).length +
  researchItems.filter((item) => !item.data.studySeries).length +
  novelItems.filter((item) => !item.data.studySeries).length;
---
<BaseLayout title="ねこねこ研究所 | ねこねこ通信">
  <section class="labIndex">
    <p class="storageLead">
      <a href={`${BASE}study/storage`}>物置</a>
      <span class="small mono">{storageCount}</span>
    </p>

    {studyUnits.length ? (
      <section class="unitSection">
        <div class="unitGrid">
          {studyUnits.map((unit) => (
            <a class="unitCard" href={unit.href}>
              {unit.thumb ? <img class="unitThumb" src={unit.thumb} alt="" /> : null}
              <div class="unitBody">
                <strong class="unitTitle">{unit.title}</strong>
                <p class="unitSummary">{unit.summary}</p>
                <div class="unitMeta unitMetaFoot">
                  <span class="unitCount mono">{unit.count} セリー</span>
                </div>
                <div class="unitMeta unitMetaDate">
                  {unit.nextUpdate ? <span class="unitDate">🗓️{unit.nextUpdate}更新予定</span> : null}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    ) : null}
  </section>
</BaseLayout>

<style>
  .labIndex {
    width: min(100%, 940px);
    margin-inline: auto;
    display: grid;
    gap: 18px;
  }

  .storageLead {
    margin: 0;
    display: flex;
    align-items: baseline;
    gap: 10px;
    color: var(--muted);
  }

  .storageLead a {
    color: var(--ink);
    text-decoration: none;
  }

  .storageLead a:hover {
    opacity: 0.78;
  }

  .unitSection {
    display: grid;
    gap: 12px;
  }

  .unitGrid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .unitCard {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 16px;
    padding: 10px 0 12px;
    border-top: 1px dotted var(--line);
    color: var(--ink);
    text-decoration: none;
  }

  .unitCard:hover {
    opacity: 0.82;
  }

  .unitThumb {
    width: 100%;
    aspect-ratio: 5 / 4;
    object-fit: cover;
    display: block;
  }

  .unitBody {
    min-width: 0;
    display: grid;
    gap: 4px;
    align-content: start;
    grid-template-rows: auto auto 1fr auto auto;
  }

  .unitMeta {
    display: flex;
    flex-wrap: wrap;
    gap: 5px 10px;
    color: var(--muted);
    align-items: baseline;
    font-size: 0.68rem;
    line-height: 1.3;
  }

  .unitMetaFoot {
    grid-row: 4;
    margin-top: 2px;
  }

  .unitMetaDate {
    grid-row: 5;
    margin-top: auto;
    align-self: end;
  }

  .unitDate {
    margin: 0;
    color: #5e7894;
    opacity: 0.82;
    white-space: normal;
    font-size: 0.8rem;
    line-height: 1.35;
  }

  .unitTitle {
    font-size: 0.98rem;
    line-height: 1.35;
    font-weight: 400;
  }

  .unitSummary {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--muted);
    opacity: 0.86;
  }

  .unitCount {
    font-size: 0.68rem;
    color: var(--muted);
    opacity: 0.8;
  }

  @media (max-width: 760px) {
    .unitGrid {
      grid-template-columns: 1fr;
      gap: 10px;
    }

    .unitCard {
      grid-template-columns: 156px minmax(0, 1fr);
      gap: 12px;
    }
  }
</style>
