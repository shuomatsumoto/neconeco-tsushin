---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import LockGate from "../../components/LockGate.astro";
import { getDisplayTitle } from "../../utils/content";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

async function sha256Hex(text: string): Promise<string> {
  const bytes = new TextEncoder().encode(text);
  const digest = await globalThis.crypto.subtle.digest("SHA-256", bytes);
  return Array.from(new Uint8Array(digest))
    .map((byte) => byte.toString(16).padStart(2, "0"))
    .join("");
}

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const lockHash = post.data.lockPasscode ? await sha256Hex(post.data.lockPasscode) : "";
const storageKey = `posts/${post.slug}`;
const displayTitle = getDisplayTitle(post.data.title, post.data.date);

function thumbSrc(raw?: string) {
  if (!raw) return null;

  // Full URL
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;

  // Absolute path like /images/... must be prefixed with BASE on GitHub Pages
  if (raw.startsWith("/")) return `${BASE}${raw.slice(1)}`;

  // Relative path -> treat as under BASE
  const clean = raw.replace(/^\/+/, "");
  return `${BASE}${clean}`;
}
---
<BaseLayout title={`${displayTitle} | ねこねこ通信`}>
  <article class="plainArticle">
    <div class="articleMeta">
      <div class="metaLine">
        <span class="small mono dateText">{post.data.date}</span>
      </div>
    </div>

    <h1 class="h1">{displayTitle}</h1>

    <LockGate
      locked={post.data.locked}
      lockHash={lockHash}
      storageKey={storageKey}
    >
      <div class="prose">
        <Content />
      </div>

      {post.data.supportUrl ? (
        <section class="supportBox" aria-label="あと払い">
          <h2 class="supportTitle">この記事に値段を付ける</h2>
          <form
            id="supportForm"
            class="supportForm"
            action={post.data.supportUrl}
            method="get"
            target="_blank"
          >
            <input type="hidden" name="wanted" value="true" />
            <input type="hidden" name="price" id="supportPrice" value="" />
            <label class="supportAmountLabel">
              <span class="srOnly">金額</span>
              <input
                class="supportAmountInput"
                type="number"
                min="0"
                step="1"
                id="supportAmountJpy"
                inputmode="numeric"
                placeholder="0"
              />
              <span class="yenSuffix" aria-hidden="true">円</span>
            </label>
            <button class="supportButton" type="submit">決定</button>
          </form>
        </section>
      ) : null}
    </LockGate>
  </article>
</BaseLayout>

<style>
  .plainArticle {
    padding: 0;
    margin: 0;
    padding-top: 15px;
    max-width: 760px;
    margin-inline: auto;
  }

.prose :global(p) {
    margin: 0 0 1.05em;
    font-size: 1rem;
  }

  .prose :global(h2) {
    margin: 1.8em 0 0.7em;
    font-size: 1.18rem;
    font-weight: 500;
  }

  .prose :global(h3) {
    margin: 1.5em 0% 0.6em;
    font-size: 1.02rem;
    font-weight: 400;
    color: var(--muted);
    opacity: 0.9;
  }

  .prose :global(a) {
    text-decoration: underline;
  }

  .prose :global(blockquote) {
    margin: 1.2em 0;
    padding: 10px 14px;
    border-left: 3px solid var(--line);
    background: rgba(255,255,255,0.35);
    border-radius: 10px;
  }

  .articleMeta {
    display: grid;
    gap: 6px;
    font-size: 0.78rem;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .metaLine {
    display: flex;
    gap: 8px;
    align-items: baseline;
    flex-wrap: wrap;
  }

  .dateText {
    opacity: 0.78;
  }

  .plainArticle .h1 {
    font-size: clamp(1.45rem, 2.7vw, 1.82rem);
    line-height: 1.38;
    margin: 0 0 16px;
  }

  .supportBox {
    margin-top: 32px;
    padding-top: 18px;
    border-top: 1px dotted var(--line);
    display: grid;
    gap: 8px;
  }

  .supportTitle {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.4;
    color: var(--ink);
    font-weight: 500;
  }

  .supportForm {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
  }

  .supportAmountLabel {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--muted);
    font-size: 0.84rem;
  }

  .supportAmountInput {
    width: 110px;
    height: 34px;
    border: 1px solid rgba(64, 54, 40, 0.26);
    background: #fff;
    color: var(--ink);
    font: inherit;
    font-size: 0.84rem;
    padding: 0 10px;
  }

  .yenSuffix {
    line-height: 1;
    color: var(--muted);
  }

  .supportButton {
    text-decoration: none;
    border: 1px solid rgba(64, 54, 40, 0.26);
    background: #fff;
    color: var(--ink);
    font-size: 0.84rem;
    line-height: 1;
    padding: 8px 12px;
  }

  .srOnly {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
