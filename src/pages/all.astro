---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getContentSummary } from "../utils/content";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

function isNoteLike(data: { kind?: string }) {
  return data.kind === "note";
}

const postsAll = await getCollection(
  "posts",
  ({ data }) => {
    if (data.draft) return false;
    return !isNoteLike(data);
  }
);

// 最新順：date 降順 → 同日内は slug で安定化
const posts = [...postsAll].sort((a, b) => {
  if (a.data.date !== b.data.date) return a.data.date < b.data.date ? 1 : -1;
  return a.slug < b.slug ? 1 : -1;
});

function thumbSrc(raw?: string) {
  if (!raw) return null;
  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  if (raw.startsWith("/")) return `${BASE}${raw.slice(1)}`;
  return `${BASE}${raw.replace(/^\/+/, "")}`;
}

const data = posts.map((p) => ({
  slug: p.slug,
  title: p.data.title,
  summary: getContentSummary(p.data.summary, p.body ?? ""),
  date: p.data.date,
  thumb: thumbSrc(p.data.thumbnail),
}));
---
<BaseLayout title="記事一覧 | ねこねこ通信">
  <section class="catalog">
    <header class="catalogHead">
      <h2 class="h2" style="margin:0;">記事一覧</h2>
      <div class="catalogMeta">
        <div id="qHint" class="small qHint" hidden></div>
        <div class="small count"><span id="count">{data.length} 件</span></div>
      </div>
    </header>

    <div class="tools" aria-label="絞り込みと並び替え">
      <select id="sort" class="sel" aria-label="並び順">
        <option value="new">新しい順</option>
        <option value="old">古い順</option>
      </select>
    </div>

    {/* ✅ まず Astro 側で必ず表示（JSが落ちても見える） */}
    <ul id="list" class="postGrid">
      {data.map((it) => (
        <li
          class="li cardItem"
          data-title={it.title}
          data-summary={it.summary}
          data-date={it.date}
          data-slug={it.slug}
        >
          <a class="postCard" href={`${BASE}posts/${it.slug}`}>
            {it.thumb ? <img class="thumb post-thumb-wide" src={it.thumb} alt="" loading="lazy" /> : null}
            <div class="cardBody">
              <strong class="title post-title-2line">{it.title}</strong>
              <p class="date mono">{it.date}</p>
              {it.summary ? <p class="summary post-summary-2line">{it.summary}</p> : null}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>

  {/* ✅ JS は “絞り込みだけ” 担当 */}
  <script is:inline>
    const elSort = document.getElementById("sort");
    const elCount = document.getElementById("count");
    const list = document.getElementById("list");
    const qHint = document.getElementById("qHint");
    const urlQ = new URLSearchParams(window.location.search).get("q") || "";

    function norm(s){ return (s || "").toString().trim().toLowerCase(); }

    function apply(){
      const q = norm(urlQ);
      const sort = elSort.value;

      const items = Array.from(list.querySelectorAll("li.li"));

      // 絞り込み
      let visible = [];
      for (const li of items) {
        const title = (li.dataset.title || "").toLowerCase();
        const summary = (li.dataset.summary || "").toLowerCase();

        if (q && !(title.includes(q) || summary.includes(q))) {
          li.style.display = "none"; continue;
        }

        li.style.display = "";
        visible.push(li);
      }

      // 並び替え（date→slug）
      visible.sort((a,b)=>{
        const da = a.dataset.date || "";
        const db = b.dataset.date || "";
        if (da !== db) return sort === "new" ? (da < db ? 1 : -1) : (da > db ? 1 : -1);
        const sa = a.dataset.slug || "";
        const sb = b.dataset.slug || "";
        return sort === "new" ? (sa < sb ? 1 : -1) : (sa > sb ? 1 : -1);
      });

      // DOM並べ替え
      for (const li of visible) list.appendChild(li);

      elCount.textContent = `${visible.length} 件`;
    }

    if (qHint && urlQ.trim()) {
      qHint.hidden = false;
      qHint.textContent = `検索: 「${urlQ.trim()}」`;
    }

    elSort.addEventListener("change", apply);
    apply();
  </script>

  <style>
    .catalog {
      width: min(100%, 940px);
      margin-inline: auto;
      display: grid;
      gap: 14px;
    }

    .catalogHead {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 12px;
      flex-wrap: wrap;
      padding-top: 4px;
    }

    .catalogMeta {
      display: flex;
      align-items: baseline;
      gap: 10px;
      flex-wrap: wrap;
    }

    .tools {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      padding-bottom: 10px;
      border-bottom: 1px dotted var(--line);
    }

    .qHint {
      color: var(--muted);
      font-size: 0.8rem;
      opacity: 0.82;
    }

    .count {
      font-size: 0.8rem;
      color: var(--muted);
      opacity: 0.82;
    }

    .sel {
      min-width: 130px;
      height: 30px;
      padding: 0 9px;
      border: 1px solid rgba(64, 54, 40, 0.2);
      border-radius: 0;
      background: #fff;
      color: var(--ink);
      font-family: inherit;
      font-size: 0.8rem;
    }

    .postGrid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0;
    }

    .cardItem {
      min-width: 0;
    }

    .postCard {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      gap: 8px;
      text-decoration: none;
      color: var(--ink);
      border-bottom: 1px dotted var(--line);
      background: transparent;
      padding: 10px 0 12px;
      transition: opacity 0.16s ease;
    }

    .postCard:hover {
      opacity: 0.82;
    }

    .thumb {
      aspect-ratio: 8 / 5;
      margin: 0;
      width: 100%;
      height: auto;
      border: 0;
    }

    .cardBody {
      min-width: 0;
      display: grid;
      gap: 2px;
      align-content: start;
      padding: 0;
    }

    .date {
      margin: 0;
      font-size: 0.68rem;
      color: var(--muted);
      opacity: 0.78;
      white-space: nowrap;
    }

    .title {
      display: block;
      font-size: 0.92rem;
      line-height: 1.35;
      color: var(--ink);
      font-weight: 400;
    }

    .summary {
      margin: 0;
      font-size: 0.8rem;
      line-height: 1.45;
      color: var(--muted);
      opacity: 0.86;
    }

    @media (max-width: 640px) {
      .catalogHead {
        align-items: flex-start;
      }

      .tools {
        gap: 6px;
      }

      .sel {
        width: 100%;
      }

      .postCard {
        padding: 9px 0;
      }
    }
  </style>
</BaseLayout>
